<svg width="300" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="animalGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4CAF50;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2E7D32;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- 背景 -->
  <rect width="300" height="200" fill="#E8F5E8"/>
  
  <!-- 动物轮廓 -->
  <ellipse cx="150" cy="120" rx="60" ry="40" fill="url(#animalGradient)"/>
  
  <!-- 鸟头 -->
  <circle cx="120" cy="100" r="25" fill="url(#animalGradient)"/>
  
  <!-- 鸟嘴 -->
  <polygon points="95,100 85,95 85,105" fill="#FF9800"/>
  
  <!-- 眼睛 -->
  <circle cx="115" cy="95" r="4" fill="white"/>
  <circle cx="115" cy="95" r="2" fill="black"/>
  
  <!-- 翅膀 -->
  <ellipse cx="170" cy="110" rx="30" ry="20" fill="#388E3C"/>
  
  <!-- 尾巴 -->
  <ellipse cx="200" cy="130" rx="25" ry="15" fill="#2E7D32"/>
  
  <!-- 文字 -->
  <text x="150" y="170" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" fill="#666">
    动物图片
  </text>
</svg>